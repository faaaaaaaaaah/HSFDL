{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "dist-electron",
    "rootDir": "src",
    "baseUrl": "src",
    "paths": {
      "@main/*": ["main/*"],
      "@shared/*": ["shared/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": false
  },
  "include": [
    "src/main/**/*.ts",
    "src/shared/**/*.ts",
    "src/buildinfo.json"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-electron",
    "dist-package"
  ]
}
