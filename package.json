{
  "name": "hsfdl-downloader",
  "version": "1.0.0",
  "description": "Premium High Speed File Downloader",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "tsc -p tsconfig.main.json && vite build",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "lucide-react": "^0.435.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "build": {
    "appId": "com.hsfdl.downloader",
    "productName": "HSFDL Downloader",
    "directories": {
      "output": "dist-package"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable"
    }
  }
}
